{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Searchy",
  "version": "0.1.0",
  "identifier": "dev.searchy.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Searchy",
        "width": 860,
        "height": 560,
        "minWidth": 760,
        "minHeight": 500,
        "resizable": false,
        "visible": false,
        "center": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
